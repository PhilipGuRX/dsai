# City Congestion Tracker — copy to .env and fill in values.
# Do not commit .env (secrets). Use this file for reproducibility.

# Supabase (required for API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# AI: use one of ollama_cloud or openai
AI_BACKEND=ollama_cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_CLOUD_MODEL=gpt-oss:20b

# Optional: OpenAI instead of Ollama
# AI_BACKEND=openai
# OPENAI_API_KEY=your-openai-api-key

# Dashboard (optional; defaults to http://localhost:8000 when unset)
API_BASE_URL=http://localhost:8000
CITY_NAME=Metro City
